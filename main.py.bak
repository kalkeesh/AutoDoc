def append_pending_note_to_document():
    note = get_note_text()
    if not note or not document or not doc_path:
        return

    add_note_to_document(note)
    document.save(doc_path)
    clear_note()


def close_toast():
    global toast_window, toast_after_id

    if toast_after_id is not None:
        root.after_cancel(toast_after_id)
        toast_after_id = None

    if toast_window is not None and toast_window.winfo_exists():
        toast_window.destroy()
    toast_window = None


def show_toast(message, duration_ms=3000):
    global toast_window, toast_after_id

    close_toast()

    toast_window = tk.Toplevel(root)
    toast_window.overrideredirect(True)
    toast_window.attributes("-topmost", True)
    toast_window.configure(bg="#188038")

    label = tk.Label(
        toast_window,
        text=message,
        bg="#188038",
        fg="white",
        font=("Segoe UI Semibold", 12),
        padx=22,
        pady=14,
    )
    label.pack()

    screen_width = root.winfo_screenwidth()
    screen_height = root.winfo_screenheight()
    toast_window.update_idletasks()
    width = toast_window.winfo_width()
    height = toast_window.winfo_height()
    x = int((screen_width - width) / 2)
    y = max(24, int(screen_height * 0.08))
    toast_window.geometry(f"+{x}+{y}")

    toast_after_id = root.after(duration_ms, close_toast)


def set_preview_controls_state(has_images):
    if not preview_buttons:
        return

    state = "normal" if has_images else "disabled"
    for key in (
        "prev",
        "next",
        "delete",
        "zoom_in",
        "zoom_out",
        "pan",
        "highlight",
        "brush_S",
        "brush_M",
        "brush_L",
        "brush_XL",
    ):
        button = preview_buttons.get(key)
        if button is not None and button.winfo_exists():
            button.configure(state=state)


def update_preview_canvas():
    global preview_photo, preview_base_image, preview_annotated_image, preview_annotation_draw, preview_last_point
    global preview_image_path, preview_display_size, preview_dirty, preview_pan_x, preview_pan_y

    if (
        preview_window is None
        or not preview_window.winfo_exists()
        or preview_canvas is None
        or not preview_canvas.winfo_exists()
    ):
        return

    refresh_preview_paths()
    if not preview_paths:
        preview_canvas.delete("all")
        preview_canvas.create_text(
            190,
            150,
            text="No screenshots yet.\nTake one and it will appear here.",
            fill="#5d6880",
            font=("Segoe UI", 11),
            justify="center",
        )
        preview_index_var.set("0 / 0")
        preview_image_path = None
        preview_base_image = None
        preview_annotated_image = None
        preview_annotation_draw = None
        preview_last_point = None
        preview_dirty = False
        set_preview_controls_state(False)
        return

    current_index = max(0, min(len(preview_paths) - 1, getattr(update_preview_canvas, "current_index", len(preview_paths) - 1)))
    update_preview_canvas.current_index = current_index
    image_path = preview_paths[current_index]

    if preview_image_path != image_path or preview_base_image is None:
        base_image = Image.open(image_path).convert("RGBA")
        preview_base_image = base_image
        preview_annotated_image = base_image.copy()
        preview_annotation_draw = Image.new("RGBA", base_image.size, (0, 0, 0, 0))
        preview_image_path = image_path
        preview_dirty = False
        preview_pan_x = 0
        preview_pan_y = 0

    canvas_width = max(240, preview_canvas.winfo_width())
    canvas_height = max(180, preview_canvas.winfo_height())
    display_image = Image.alpha_composite(preview_annotated_image, preview_annotation_draw)
    viewport_width = max(80, canvas_width - 16)
    viewport_height = max(80, canvas_height - 16)
    base_scale = min(viewport_width / display_image.width, viewport_height / display_image.height)
    render_scale = base_scale * preview_zoom
    scaled_width = max(1, int(display_image.width * render_scale))
    scaled_height = max(1, int(display_image.height * render_scale))
    scaled_image = display_image.resize((scaled_width, scaled_height), Image.Resampling.LANCZOS)

    max_pan_x = max(0, (scaled_width - viewport_width) / 2)
    max_pan_y = max(0, (scaled_height - viewport_height) / 2)
    preview_pan_x = max(-max_pan_x, min(max_pan_x, preview_pan_x))
    preview_pan_y = max(-max_pan_y, min(max_pan_y, preview_pan_y))

    viewport = Image.new("RGBA", (viewport_width, viewport_height), (239, 243, 255, 255))
    paste_x = int((viewport_width - scaled_width) / 2 + preview_pan_x)
    paste_y = int((viewport_height - scaled_height) / 2 + preview_pan_y)
    viewport.paste(scaled_image, (paste_x, paste_y), scaled_image)

    preview_display_size = (scaled_width, scaled_height)
    preview_photo = ImageTk.PhotoImage(viewport)

    preview_canvas.delete("all")
    preview_canvas.create_rectangle(0, 0, canvas_width, canvas_height, fill="#eff3ff", outline="")
    preview_canvas.create_image(canvas_width / 2, canvas_height / 2, image=preview_photo)
    preview_canvas.create_rectangle(
        8,
        8,
        canvas_width - 8,
        canvas_height - 8,
        outline="#cfd7ef",
        width=1,
    )

    preview_index_var.set(f"{current_index + 1} / {len(preview_paths)}")
    set_preview_controls_state(True)


update_preview_canvas.current_index = 0


def show_preview_at(index):
    if preview_paths:
        update_preview_canvas.current_index = max(0, min(len(preview_paths) - 1, index))
    update_preview_canvas()


def zoom_preview(delta):
    global preview_zoom, preview_pan_x, preview_pan_y

    preview_zoom = max(1.0, min(3.0, preview_zoom + delta))
    if preview_zoom == 1.0:
        preview_pan_x = 0
        preview_pan_y = 0
    update_preview_canvas()


def adjust_preview_brush_size(delta):
    global preview_brush_index, preview_brush_size

    direction = 1 if delta > 0 else -1
    preview_brush_index = max(0, min(len(PREVIEW_BRUSH_LEVELS) - 1, preview_brush_index + direction))
    preview_brush_size = PREVIEW_BRUSH_LEVELS[preview_brush_index]
    update_preview_brush_buttons()


def set_preview_brush_level(index):
    global preview_brush_index, preview_brush_size

    preview_brush_index = max(0, min(len(PREVIEW_BRUSH_LEVELS) - 1, index))
    preview_brush_size = PREVIEW_BRUSH_LEVELS[preview_brush_index]
    update_preview_brush_buttons()


def update_preview_brush_buttons():
    for index, label in enumerate(("S", "M", "L", "XL")):
        button = preview_buttons.get(f"brush_{label}")
        if button is None or not button.winfo_exists():
            continue
        is_active = index == preview_brush_index
        button.configure(
            bg="#ffe89a" if is_active else CARD_BG,
            fg="#7a5b00" if is_active else TEXT_DARK,
        )


def set_preview_tool_mode(mode):
    global preview_tool_mode

    preview_tool_mode = mode
    if preview_canvas is not None and preview_canvas.winfo_exists():
        preview_canvas.configure(cursor="fleur" if mode == "pan" else "pencil")

    pan_button = preview_buttons.get("pan")
    highlight_button = preview_buttons.get("highlight")
    if pan_button is not None and pan_button.winfo_exists():
        pan_button.configure(fg=PRIMARY_BLUE if mode == "pan" else TEXT_DARK)
    if highlight_button is not None and highlight_button.winfo_exists():
        highlight_button.configure(fg="#b58900" if mode == "highlight" else TEXT_DARK)


def start_preview_interaction(event):
    global preview_drag_origin, preview_last_point

    preview_drag_origin = (event.x, event.y)
    if preview_tool_mode == "highlight":
        preview_last_point = preview_canvas_to_image_coords(event)
    else:
        preview_last_point = None


def drag_preview_interaction(event):
    global preview_drag_origin, preview_pan_x, preview_pan_y, preview_last_point, preview_dirty

    if preview_tool_mode == "highlight":
        if preview_annotation_draw is None:
            return

        point = preview_canvas_to_image_coords(event)
        if point is None:
            preview_last_point = None
            return

        if preview_last_point is None:
            preview_last_point = point
            return

        draw = ImageDraw.Draw(preview_annotation_draw)
        draw.line(
            (preview_last_point[0], preview_last_point[1], point[0], point[1]),
            fill=(255, 235, 59, 150),
            width=preview_brush_size,
        )
        preview_last_point = point
        preview_dirty = True
        update_preview_canvas()
        return

    if preview_drag_origin is None:
        preview_drag_origin = (event.x, event.y)
        return

    dx = event.x - preview_drag_origin[0]
    dy = event.y - preview_drag_origin[1]
    preview_drag_origin = (event.x, event.y)
    preview_pan_x += dx
    preview_pan_y += dy
    update_preview_canvas()


def end_preview_interaction(_event):
    global preview_drag_origin, preview_last_point

    should_auto_save = preview_tool_mode == "highlight" and preview_dirty
    preview_drag_origin = None
    preview_last_point = None
    if should_auto_save:
        save_preview_highlight()


def open_preview_window():
    global preview_window, preview_canvas, preview_index_var, preview_buttons

    if preview_window is not None and preview_window.winfo_exists():
        preview_window.deiconify()
        preview_window.lift()
        preview_window.focus_force()
        update_preview_canvas()
        return

    preview_window = tk.Toplevel(root)
    preview_window.title("Screenshot Preview")
    preview_window.geometry("980x760+760+100")
    preview_window.minsize(860, 680)
    preview_window.configure(bg=CARD_BG)
    preview_window.attributes("-topmost", True)

    top_bar = tk.Frame(preview_window, bg=CARD_BG)
    top_bar.pack(fill="x", padx=14, pady=(14, 8))

    preview_buttons["prev"] = tk.Button(
        top_bar,
        text="\u2190",
        command=lambda: show_preview_at(update_preview_canvas.current_index - 1),
        relief="flat",
        bg=CARD_BG,
        activebackground="#eef2ff",
        fg=TEXT_DARK,
        font=("Segoe UI Symbol", 13),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["prev"].pack(side="left")

    preview_index_var = tk.StringVar(value="0 / 0")
    tk.Label(
        top_bar,
        textvariable=preview_index_var,
        bg=CARD_BG,
        fg=TEXT_DARK,
        font=("Segoe UI Semibold", 12),
    ).pack(side="left", padx=10)

    preview_buttons["next"] = tk.Button(
        top_bar,
        text="\u2192",
        command=lambda: show_preview_at(update_preview_canvas.current_index + 1),
        relief="flat",
        bg=CARD_BG,
        activebackground="#eef2ff",
        fg=TEXT_DARK,
        font=("Segoe UI Symbol", 13),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["next"].pack(side="left")

    preview_buttons["zoom_out"] = tk.Button(
        top_bar,
        text="-",
        command=lambda: zoom_preview(-0.25),
        relief="flat",
        bg=CARD_BG,
        activebackground="#eef2ff",
        fg=TEXT_DARK,
        font=("Segoe UI Semibold", 12),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["zoom_out"].pack(side="left", padx=(16, 0))

    preview_buttons["zoom_in"] = tk.Button(
        top_bar,
        text="+",
        command=lambda: zoom_preview(0.25),
        relief="flat",
        bg=CARD_BG,
        activebackground="#eef2ff",
        fg=TEXT_DARK,
        font=("Segoe UI Semibold", 12),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["zoom_in"].pack(side="left", padx=(8, 0))

    preview_buttons["pan"] = tk.Button(
        top_bar,
        text="\u270b",
        command=lambda: set_preview_tool_mode("pan"),
        relief="flat",
        bg=CARD_BG,
        activebackground="#eef2ff",
        fg=PRIMARY_BLUE,
        font=("Segoe UI Symbol", 12),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["pan"].pack(side="left", padx=(16, 0))

    preview_buttons["highlight"] = tk.Button(
        top_bar,
        text="\u270e",
        command=lambda: set_preview_tool_mode("highlight"),
        relief="flat",
        bg=CARD_BG,
        activebackground="#fff6d8",
        fg=TEXT_DARK,
        font=("Segoe UI Symbol", 12),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["highlight"].pack(side="left", padx=(8, 0))

    tk.Label(
        top_bar,
        bg=CARD_BG,
        fg="#6d7891",
        font=("Segoe UI Semibold", 9),
        text="Brush",
    ).pack(side="left", padx=(16, 4))

    for index, label in enumerate(("S", "M", "L", "XL")):
        preview_buttons[f"brush_{label}"] = tk.Button(
            top_bar,
            text=label,
            command=lambda idx=index: set_preview_brush_level(idx),
            relief="flat",
            bg=CARD_BG,
            activebackground="#fff6d8",
            fg=TEXT_DARK,
            font=("Segoe UI Semibold", 9),
            bd=0,
            width=3,
            pady=2,
        )
        preview_buttons[f"brush_{label}"].pack(side="left", padx=(4 if index else 0, 0))

    preview_buttons["delete"] = tk.Button(
        top_bar,
        text="\U0001F5D1",
        command=delete_current_preview_image,
        relief="flat",
        bg=CARD_BG,
        activebackground="#ffecef",
        fg="#8b1e2d",
        font=("Segoe UI Symbol", 12),
        bd=0,
        width=2,
        pady=1,
    )
    preview_buttons["delete"].pack(side="right")

    preview_canvas = tk.Canvas(
        preview_window,
        width=920,
        height=590,
        bg="#eff3ff",
        highlightthickness=1,
        highlightbackground="#d9deea",
        cursor="fleur",
    )
    preview_canvas.pack(fill="both", expand=True, padx=14, pady=(0, 10))
    preview_canvas.bind("<Configure>", lambda _event: update_preview_canvas())
    preview_canvas.bind("<ButtonPress-1>", start_preview_interaction)
    preview_canvas.bind("<B1-Motion>", drag_preview_interaction)
    preview_canvas.bind("<ButtonRelease-1>", end_preview_interaction)

    action_bar = tk.Frame(preview_window, bg=CARD_BG)
    action_bar.pack(fill="x", padx=14, pady=(0, 12))

    tk.Button(
        action_bar,
        text="Reset",
        command=reset_preview_highlight,
        relief="flat",
        bg="#fff4c2",
        fg="#7a5b00",
        padx=10,
        pady=4,
    ).pack(side="left")

    preview_window.protocol("WM_DELETE_WINDOW", close_preview_window)
    set_preview_tool_mode("pan")
    update_preview_brush_buttons()
    show_preview_at(len(refresh_preview_paths()) - 1)


def close_preview_window():
    global preview_window, preview_canvas, preview_photo, preview_image_path, preview_base_image
    global preview_annotated_image, preview_annotation_draw, preview_last_point, preview_dirty, preview_zoom
    global preview_pan_x, preview_pan_y, preview_drag_origin, preview_tool_mode, preview_brush_index
    global preview_brush_size

    if preview_window is not None and preview_window.winfo_exists():
        preview_window.destroy()

    preview_window = None
    preview_canvas = None
    preview_photo = None
    preview_image_path = None
    preview_base_image = None
    preview_annotated_image = None
    preview_annotation_draw = None
    preview_last_point = None
    preview_dirty = False
    preview_zoom = 1.0
    preview_pan_x = 0
    preview_pan_y = 0
    preview_drag_origin = None
    preview_tool_mode = "pan"
    preview_brush_index = 1
    preview_brush_size = PREVIEW_BRUSH_LEVELS[preview_brush_index]
    preview_buttons.clear()


def preview_canvas_to_image_coords(event):
    if preview_base_image is None or preview_canvas is None or preview_photo is None:
        return None

    canvas_width = max(240, preview_canvas.winfo_width())
    canvas_height = max(180, preview_canvas.winfo_height())
    viewport_width = max(80, canvas_width - 16)
    viewport_height = max(80, canvas_height - 16)
    display_width, display_height = preview_display_size
    origin_x = 8 + (viewport_width - display_width) / 2 + preview_pan_x
    origin_y = 8 + (viewport_height - display_height) / 2 + preview_pan_y

    if not (origin_x <= event.x <= origin_x + display_width and origin_y <= event.y <= origin_y + display_height):
        return None

    scale_x = preview_base_image.width / display_width
    scale_y = preview_base_image.height / display_height
    image_x = int((event.x - origin_x) * scale_x)
    image_y = int((event.y - origin_y) * scale_y)
    return image_x, image_y


def reset_preview_highlight():
    global preview_base_image, preview_annotated_image, preview_annotation_draw, preview_dirty

    if preview_base_image is None:
        return

    backup_path = get_screenshot_backup_path(preview_image_path) if preview_image_path else None

    if backup_path and os.path.exists(backup_path) and preview_image_path:
        restored_image = Image.open(backup_path).convert("RGB")
        restored_image.save(preview_image_path)
        preview_base_image = restored_image.convert("RGBA")
        preview_annotated_image = preview_base_image.copy()
        preview_annotation_draw = Image.new("RGBA", preview_base_image.size, (0, 0, 0, 0))
        preview_dirty = False

        if document and doc_path:
            remove_tracked_image_from_document(preview_image_path)
            append_image_to_document(preview_image_path, width=Inches(5))
            document.save(doc_path)

        update_preview_canvas()
        set_status(f"Reset screenshot to original in {os.path.basename(doc_path)}" if doc_path else "Reset screenshot to original.")
        return

    if preview_dirty:
        preview_annotation_draw = Image.new("RGBA", preview_base_image.size, (0, 0, 0, 0))
        preview_dirty = False
        update_preview_canvas()
        set_status("Unsaved highlight cleared.")
        return

    set_status("Reset needs an original backup for this screenshot.")


def save_preview_highlight():
    global preview_base_image, preview_annotated_image, preview_annotation_draw, preview_dirty

    if not document or not doc_path:
        messagebox.showwarning("No document", "Create or select a Word document first.")
        return

    if preview_base_image is None or preview_image_path is None:
        set_status("No screenshot selected in preview.")
        return

    if not preview_dirty:
        set_status("Add a yellow highlight first, then save it.")
        return

    ensure_screenshot_backup(preview_image_path)
    highlighted_image = Image.alpha_composite(preview_annotated_image, preview_annotation_draw).convert("RGB")
    highlighted_image.save(preview_image_path)
    preview_base_image = highlighted_image.convert("RGBA")
    preview_annotated_image = preview_base_image.copy()
    preview_annotation_draw = Image.new("RGBA", preview_base_image.size, (0, 0, 0, 0))
    remove_tracked_image_from_document(preview_image_path)
    append_image_to_document(preview_image_path, width=Inches(5))
    document.save(doc_path)
    preview_dirty = False
    refresh_preview_paths()
    update_preview_canvas()
    set_status(f"Saved highlighted screenshot to {os.path.basename(doc_path)}")


def delete_current_preview_image():
    global preview_image_path

    if preview_image_path is None:
        set_status("No screenshot selected to delete.")
        return

    image_name = os.path.basename(preview_image_path)
    backup_path = get_screenshot_backup_path(preview_image_path)
    try:
        if document and doc_path:
            remove_tracked_image_from_document(preview_image_path)
            document.save(doc_path)
        os.remove(preview_image_path)
        if os.path.exists(backup_path):
            os.remove(backup_path)
    except Exception as exc:
        messagebox.showerror("Delete failed", f"Could not delete screenshot.\n\n{exc}")
        return

    refresh_preview_paths()
    if preview_paths:
        show_preview_at(min(update_preview_canvas.current_index, len(preview_paths) - 1))
    else:
        update_preview_canvas.current_index = 0
        update_preview_canvas()

    show_toast("Screenshot deleted")
    set_status(f"Deleted screenshot: {image_name}")


def take_screenshot(exclude_taskbar=False):
    take_screenshot_with_mode(exclude_taskbar=exclude_taskbar, use_region_selector=False)


def take_region_screenshot():
    take_screenshot_with_mode(exclude_taskbar=False, use_region_selector=True)


def select_capture_region(base_image):
    selection = {"start": None, "end": None, "result": None}
    overlay = tk.Toplevel(root)
    overlay.overrideredirect(True)
    overlay.attributes("-topmost", True)
    overlay.geometry(
        f"{base_image.width}x{base_image.height}+0+0"
    )
    overlay.configure(bg="black")

    overlay_photo = ImageTk.PhotoImage(base_image)
    canvas_overlay = tk.Canvas(overlay, width=base_image.width, height=base_image.height, highlightthickness=0, cursor="crosshair")
    canvas_overlay.pack(fill="both", expand=True)
    canvas_overlay.create_image(0, 0, image=overlay_photo, anchor="nw")
    shade = canvas_overlay.create_rectangle(0, 0, base_image.width, base_image.height, fill="black", stipple="gray50", outline="")
    rect = canvas_overlay.create_rectangle(0, 0, 0, 0, outline="#f7d038", width=2)
    hint = canvas_overlay.create_text(
        24,
        24,
        anchor="nw",
        text="Drag to capture a region. Press Esc to cancel.",
        fill="white",
        font=("Segoe UI Semibold", 12),
    )
    size_hint = canvas_overlay.create_text(
        24,
        52,
        anchor="nw",
        text="",
        fill="#ffe89a",
        font=("Segoe UI Semibold", 10),
    )
    canvas_overlay.tag_raise(rect)
    canvas_overlay.tag_raise(hint)
    canvas_overlay.tag_raise(size_hint)

    def on_press(event):
        selection["start"] = (event.x, event.y)
        selection["end"] = (event.x, event.y)
        canvas_overlay.coords(rect, event.x, event.y, event.x, event.y)

    def on_drag(event):
        if selection["start"] is None:
            return
        selection["end"] = (event.x, event.y)
        x1, y1 = selection["start"]
        x2, y2 = selection["end"]
        canvas_overlay.coords(rect, x1, y1, x2, y2)
        width = abs(x2 - x1)
        height = abs(y2 - y1)
        canvas_overlay.itemconfigure(size_hint, text=f"Size: {width} x {height}")

    def finish_selection(_event=None):
        if selection["start"] is None or selection["end"] is None:
            selection["result"] = None
        else:
            x1, y1 = selection["start"]
            x2, y2 = selection["end"]
            left, right = sorted((max(0, x1), min(base_image.width, x2)))
            top, bottom = sorted((max(0, y1), min(base_image.height, y2)))
            if right - left < 4 or bottom - top < 4:
                selection["result"] = None
            else:
                selection["result"] = (left, top, right, bottom)
        overlay.destroy()

    def cancel_selection(_event=None):
        selection["result"] = None
        overlay.destroy()

    canvas_overlay.bind("<ButtonPress-1>", on_press)
    canvas_overlay.bind("<B1-Motion>", on_drag)
    canvas_overlay.bind("<ButtonRelease-1>", finish_selection)
    overlay.bind("<Escape>", cancel_selection)
    overlay.grab_set()
    overlay.focus_force()
    overlay.wait_window()
    return selection["result"]


def take_screenshot_with_mode(exclude_taskbar=False, use_region_selector=False):
    if not document or not doc_path:
        messagebox.showwarning("No document", "Create or select a Word document first.")
        return

    note = get_note_text()
    screenshot_dir = ensure_screenshot_dir()
    note_was_visible = note_window is not None and note_window.winfo_exists() and note_window.state() != "withdrawn"
    preview_was_visible = (
        preview_window is not None
        and preview_window.winfo_exists()
        and preview_window.state() != "withdrawn"
    )

    if note_was_visible:
        save_note_from_window(close_after=False)
        note_window.withdraw()
    if preview_was_visible:
        preview_window.withdraw()

    root.withdraw()
    time.sleep(0.3)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    suffix = "_notaskbar" if exclude_taskbar else ""
    img_path = os.path.join(screenshot_dir, f"screenshot_{timestamp}{suffix}.png")

    try:
        screenshot = capture_image(exclude_taskbar=exclude_taskbar)
        if use_region_selector:
            region = select_capture_region(screenshot)
            if region is None:
                set_status("Region capture cancelled.")
                return
            screenshot = screenshot.crop(region)
        screenshot.save(img_path)
        ensure_screenshot_backup(img_path)

        if note:
            add_note_to_document(note)

        append_image_to_document(img_path, width=Inches(5))
        document.save(doc_path)
    except Exception as exc:
        messagebox.showerror("Capture failed", f"Could not save screenshot.\n\n{exc}")
        set_status("Screenshot failed.")
    else:
        clear_note()
        refresh_preview_paths()
        if preview_window is not None and preview_window.winfo_exists():
            show_preview_at(len(preview_paths) - 1)
        show_toast("Screenshot added")
        if use_region_selector:
            capture_mode = "selected region"
        else:
            capture_mode = "without taskbar" if exclude_taskbar else "with taskbar"
        set_status(f"Saved screenshot {capture_mode} to {img_path}")
    finally:
        root.deiconify()
        if note_was_visible and note_window is not None and note_window.winfo_exists():
            note_window.deiconify()
            note_window.lift()
        if preview_was_visible and preview_window is not None and preview_window.winfo_exists():
            preview_window.deiconify()
            preview_window.lift()


def trigger_screenshot_shortcut(_event=None):
    take_screenshot()
    return "break"


def trigger_workarea_screenshot_shortcut(_event=None):
    take_screenshot(exclude_taskbar=True)
    return "break"


def start_global_hotkey():
    if os.name != "nt":
        return

    thread = threading.Thread(target=hotkey_listener_loop, daemon=True)
    thread.start()


def hotkey_listener_loop():
    global hotkey_thread_id, hotkey_registered, workarea_hotkey_registered

    user32 = ctypes.windll.user32
    kernel32 = ctypes.windll.kernel32
    hotkey_thread_id = kernel32.GetCurrentThreadId()

    if not user32.RegisterHotKey(None, HOTKEY_ID, MOD_CONTROL | MOD_ALT, VK_Q):
        root.after(0, lambda: set_status(f"Global shortcut unavailable: {SHOT_SHORTCUT_LABEL}"))
    else:
        hotkey_registered = True

    if not user32.RegisterHotKey(None, WORKAREA_HOTKEY_ID, MOD_CONTROL | MOD_ALT, VK_W):
        root.after(0, lambda: set_status(f"Taskbar-free shortcut unavailable: {WORKAREA_SHORTCUT_LABEL}"))
    else:
        workarea_hotkey_registered = True

    if not hotkey_registered and not workarea_hotkey_registered:
        return

    msg = wintypes.MSG()

    while user32.GetMessageW(ctypes.byref(msg), None, 0, 0) != 0:
        if msg.message == WM_HOTKEY and msg.wParam == HOTKEY_ID:
            root.after(0, take_screenshot)
        elif msg.message == WM_HOTKEY and msg.wParam == WORKAREA_HOTKEY_ID:
            root.after(0, lambda: take_screenshot(exclude_taskbar=True))
        user32.TranslateMessage(ctypes.byref(msg))
        user32.DispatchMessageW(ctypes.byref(msg))

    if hotkey_registered:
        user32.UnregisterHotKey(None, HOTKEY_ID)
        hotkey_registered = False
    if workarea_hotkey_registered:
        user32.UnregisterHotKey(None, WORKAREA_HOTKEY_ID)
        workarea_hotkey_registered = False


def stop_global_hotkey():
    global hotkey_registered, workarea_hotkey_registered, hotkey_thread_id

    if os.name != "nt":
        return

    user32 = ctypes.windll.user32

    if hotkey_registered:
        user32.UnregisterHotKey(None, HOTKEY_ID)
        hotkey_registered = False

    if workarea_hotkey_registered:
        user32.UnregisterHotKey(None, WORKAREA_HOTKEY_ID)
        workarea_hotkey_registered = False

    if hotkey_thread_id:
        user32.PostThreadMessageW(hotkey_thread_id, WM_QUIT, 0, 0)
        hotkey_thread_id = None


def close_app():
    try:
        append_pending_note_to_document()
        clear_screenshot_dir()
    except Exception as exc:
        messagebox.showerror("Close failed", f"Could not finish saving/cleanup before closing.\n\n{exc}")
        return

    close_toast()
    close_preview_window()
    if note_window is not None and note_window.winfo_exists():
        note_window.destroy()
    if title_window is not None and title_window.winfo_exists():
        title_window.destroy()
    stop_global_hotkey()
    root.destroy()


def set_status(message):
    status_var.set(message)


def set_scale_from_slider(value):
    apply_ui_scale(float(value))


def open_size_window(_event=None):
    global size_window, size_slider

    if size_window is not None and size_window.winfo_exists():
        size_window.deiconify()
        size_window.lift()
        size_window.focus_force()
        return

    size_window = tk.Toplevel(root)
    size_window.title("Resize Tool")
    size_window.geometry(f"320x140+{root.winfo_x() + scaled(460)}+{root.winfo_y() + 40}")
    size_window.configure(bg=CARD_BG)
    size_window.attributes("-topmost", True)

    tk.Label(
        size_window,
        text="Adjust floating tool size",
        bg=CARD_BG,
        fg=TEXT_DARK,
        font=("Segoe UI Semibold", 11),
    ).pack(anchor="w", padx=16, pady=(14, 8))

    size_slider = tk.Scale(
        size_window,
        from_=int(MIN_SCALE * 100),
        to=int(MAX_SCALE * 100),
        orient="horizontal",
        command=set_scale_from_slider,
        bg=CARD_BG,
        fg=TEXT_DARK,
        highlightthickness=0,
        length=260,
    )
    size_slider.pack(padx=16, fill="x")
    size_slider.set(int(ui_scale * 100))

    tk.Label(
        size_window,
        text="Tip: right-click the floating tool anytime to resize it.",
        bg=CARD_BG,
        fg="#5d6880",
        font=("Segoe UI", 9),
    ).pack(anchor="w", padx=16, pady=(6, 10))

    size_window.protocol("WM_DELETE_WINDOW", lambda: close_size_window())


def close_size_window():
    global size_window, size_slider

    if size_window is not None and size_window.winfo_exists():
        size_window.destroy()
    size_window = None
    size_slider = None


def apply_ui_scale(new_scale):
    global ui_scale

    ui_scale = max(MIN_SCALE, min(MAX_SCALE, new_scale))
    if size_slider is not None and size_slider.winfo_exists():
        current = int(float(size_slider.get()))
        target = int(ui_scale * 100)
        if current != target:
            size_slider.set(target)
    render_main_ui()


def show_tooltip(text, x, y):
    global tooltip_window

    hide_tooltip()
    tooltip_window = tk.Toplevel(root)
    tooltip_window.overrideredirect(True)
    tooltip_window.attributes("-topmost", True)
    tooltip_window.configure(bg="#182235")
    tooltip_window.geometry(f"+{x + 14}+{y + 10}")

    label = tk.Label(
        tooltip_window,
        text=text,
        bg="#182235",
        fg="white",
        font=("Segoe UI", 9),
        padx=10,
        pady=6,
        justify="left",
    )
    label.pack()


def hide_tooltip():
    global tooltip_window

    if tooltip_window is not None and tooltip_window.winfo_exists():
        tooltip_window.destroy()
    tooltip_window = None


def run_single_click_command(command):
    global pending_click_after_id
    pending_click_after_id = None
    command()


def bind_button_events(items, command, tooltip_text, double_command=None):
    for item in items:
        if double_command is None:
            def on_click(_event, cmd=command):
                cmd()
                return "break"

            canvas.tag_bind(item, "<Button-1>", on_click)
        else:
            def on_single_click(_event, cmd=command):
                global pending_click_after_id
                if pending_click_after_id is not None:
                    root.after_cancel(pending_click_after_id)
                pending_click_after_id = root.after(
                    SHOT_SINGLE_CLICK_DELAY_MS,
                    lambda: run_single_click_command(cmd),
                )
                return "break"

            def on_double_click(_event, cmd=double_command):
                global pending_click_after_id
                if pending_click_after_id is not None:
                    root.after_cancel(pending_click_after_id)
                    pending_click_after_id = None
                cmd()
                return "break"

            canvas.tag_bind(item, "<Button-1>", on_single_click)
            canvas.tag_bind(item, "<Double-Button-1>", on_double_click)
        canvas.tag_bind(item, "<B1-Motion>", lambda _event: "break")
        canvas.tag_bind(item, "<Button-3>", lambda event: (open_size_window(event), "break")[1])
        if tooltip_text:
            canvas.tag_bind(
                item,
                "<Enter>",
                lambda event, text=tooltip_text: show_tooltip(text, event.x_root, event.y_root),
            )
            canvas.tag_bind(item, "<Leave>", lambda _event: hide_tooltip())


def bind_move_button_events(items, tooltip_text):
    for item in items:
        canvas.tag_bind(item, "<Button-1>", start_move)
        canvas.tag_bind(item, "<B1-Motion>", on_motion)
        canvas.tag_bind(item, "<Button-3>", open_size_window)
        if tooltip_text:
            canvas.tag_bind(
                item,
                "<Enter>",
                lambda event, text=tooltip_text: show_tooltip(text, event.x_root, event.y_root),
            )
            canvas.tag_bind(item, "<Leave>", lambda _event: hide_tooltip())


def draw_circle_button(x, y, size, fill, label, command, tooltip_text, label_size=11, double_command=None):
    x = scaled(x)
    y = scaled(y)
    size = scaled(size)
    label_size = scaled(label_size)
    shadow_offset = 6
    shadow = canvas.create_oval(
        x + scaled(shadow_offset),
        y + scaled(shadow_offset),
        x + size + scaled(shadow_offset),
        y + size + scaled(shadow_offset),
        fill=BUTTON_SHADOW,
        outline="",
    )
    oval = canvas.create_oval(x, y, x + size, y + size, fill=fill, outline="")
    text = canvas.create_text(
        x + size / 2,
        y + size / 2,
        text=label,
        fill="white",
        font=("Segoe UI Semibold", label_size),
        justify="center",
    )

    bind_button_events((shadow, oval, text), command, tooltip_text, double_command=double_command)


def draw_move_button(x, y, size, fill, label, tooltip_text, label_size=11):
    x = scaled(x)
    y = scaled(y)
    size = scaled(size)
    label_size = scaled(label_size)
    shadow_offset = 6
    shadow = canvas.create_oval(
        x + scaled(shadow_offset),
        y + scaled(shadow_offset),
        x + size + scaled(shadow_offset),
        y + size + scaled(shadow_offset),
        fill=BUTTON_SHADOW,
        outline="",
    )
    oval = canvas.create_oval(x, y, x + size, y + size, fill=fill, outline="")
    text = canvas.create_text(
        x + size / 2,
        y + size / 2,
        text=label,
        fill="white",
        font=("Segoe UI Semibold", label_size),
        justify="center",
    )

    bind_move_button_events((shadow, oval, text), tooltip_text)


def start_move(event):
    root.x = event.x_root - root.winfo_x()
    root.y = event.y_root - root.winfo_y()


def on_motion(event):
    x = event.x_root - root.x
    y = event.y_root - root.y
    root.geometry(f"+{x}+{y}")


def draw_background():
    canvas.create_rectangle(
        0,
        0,
        scaled(BASE_WIDTH),
        scaled(BASE_HEIGHT),
        fill=TRANSPARENT_KEY,
        outline=TRANSPARENT_KEY,
    )


def render_main_ui():
    global status_card, status_label

    current_x = root.winfo_x() if root.winfo_ismapped() else 500
    current_y = root.winfo_y() if root.winfo_ismapped() else 120
    root.geometry(f"{scaled(BASE_WIDTH)}x{scaled(BASE_HEIGHT)}+{current_x}+{current_y}")

    canvas.config(width=scaled(BASE_WIDTH), height=scaled(BASE_HEIGHT))
    canvas.delete("all")
    draw_background()

    if status_card is not None and status_card.winfo_exists():
        status_card.destroy()

    center_x = 182
    center_y = 318
    shot_size = 132
    satellite_size = 72
    shot_left = center_x - (shot_size / 2)
    shot_top = center_y - (shot_size / 2)
    draw_circle_button(
        shot_left,
        shot_top,
        shot_size,
        PRIMARY_RED,
        "Shot",
        take_screenshot,
        "",
        label_size=17,
        double_command=take_region_screenshot,
    )

    radius = 144
    button_specs = [
        ("New", create_new_document, "Create a new Word document.", 270, 10, False),
        ("File", select_document, "Open an existing Word document.", 321, 10, False),
        ("Note", open_note_window, "Open the note window.", 12, 10, False),
        ("Preview", open_preview_window, "Browse earlier screenshots and add yellow highlights.", 63, 8, False),
        ("i", open_info_window, "Show instructions.", 114, 18, False),
        ("Close", close_app, "Close the floating tool.", 165, 9, False),
        ("Move", None, "Drag this button to move the floating tool.", 216, 8, True),
    ]

    for label, command, tooltip_text, angle_deg, label_size, is_move in button_specs:
        radians = math.radians(angle_deg)
        button_center_x = center_x + radius * math.cos(radians)
        button_center_y = center_y + radius * math.sin(radians)
        button_left = button_center_x - (satellite_size / 2)
        button_top = button_center_y - (satellite_size / 2)

        if is_move:
            draw_move_button(button_left, button_top, satellite_size, PRIMARY_BLUE, label, tooltip_text, label_size=label_size)
        else:
            draw_circle_button(button_left, button_top, satellite_size, PRIMARY_BLUE, label, command, tooltip_text, label_size=label_size)


root = tk.Tk()
root.title("Tester Tool")
root.geometry(f"{scaled(BASE_WIDTH)}x{scaled(BASE_HEIGHT)}+500+120")
root.configure(bg=TRANSPARENT_KEY)
root.attributes("-topmost", True)
root.overrideredirect(True)
try:
    root.wm_attributes("-transparentcolor", TRANSPARENT_KEY)
except tk.TclError:
    pass

status_var = tk.StringVar(
    value=""
)
canvas = tk.Canvas(root, width=420, height=680, bg=TRANSPARENT_KEY, highlightthickness=0)
canvas.pack(fill="both", expand=True)
canvas.bind("<Button-1>", start_move)
canvas.bind("<B1-Motion>", on_motion)
canvas.bind("<Button-3>", open_size_window)

render_main_ui()
start_global_hotkey()

root.mainloop()
