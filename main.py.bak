def ensure_screenshot_dir():
    os.makedirs(SCREENSHOT_DIR, exist_ok=True)
    return SCREENSHOT_DIR


def ensure_screenshot_backup_dir():
    backup_dir = os.path.join(ensure_screenshot_dir(), ".originals")
    os.makedirs(backup_dir, exist_ok=True)
    return backup_dir


def get_screenshot_backup_path(image_path):
    return os.path.join(ensure_screenshot_backup_dir(), os.path.basename(image_path))


def ensure_screenshot_backup(image_path):
    backup_path = get_screenshot_backup_path(image_path)
    if os.path.exists(image_path) and not os.path.exists(backup_path):
        shutil.copyfile(image_path, backup_path)
    return backup_path


def clear_screenshot_dir():
    screenshot_dir = ensure_screenshot_dir()
    removed_count = 0

    for name in os.listdir(screenshot_dir):
        path = os.path.join(screenshot_dir, name)
        if not os.path.isfile(path):
            continue
        if not name.lower().endswith((".png", ".jpg", ".jpeg")):
            continue
        os.remove(path)
        removed_count += 1

    backup_dir = ensure_screenshot_backup_dir()
    for name in os.listdir(backup_dir):
        path = os.path.join(backup_dir, name)
        if not os.path.isfile(path):
            continue
        if not name.lower().endswith((".png", ".jpg", ".jpeg")):
            continue
        os.remove(path)

    return removed_count


def get_note_text():
    if note_window is not None and note_window.winfo_exists() and note_textbox is not None:
        return note_textbox.get("1.0", tk.END).strip()
    return current_note_text


def clear_note():
    global current_note_text
    current_note_text = ""

    if note_textbox is not None:
        note_textbox.delete("1.0", tk.END)
        for tag_name in ("bold", "italic", "bold_italic"):
            note_textbox.tag_remove(tag_name, "1.0", tk.END)

    update_note_style_buttons()


def list_saved_screenshots():
    screenshot_dir = ensure_screenshot_dir()
    paths = []
    for name in os.listdir(screenshot_dir):
        lower_name = name.lower()
        if lower_name.endswith((".png", ".jpg", ".jpeg")):
            paths.append(os.path.join(screenshot_dir, name))
    return sorted(paths, key=os.path.getmtime)


def refresh_preview_paths():
    global preview_paths
    preview_paths = list_saved_screenshots()
    return preview_paths


def get_workarea_bbox():
    if os.name != "nt":
        screenshot = pyautogui.screenshot()
        return (0, 0, screenshot.width, screenshot.height)

    rect = wintypes.RECT()
    ctypes.windll.user32.SystemParametersInfoW(SPI_GETWORKAREA, 0, ctypes.byref(rect), 0)
    return (rect.left, rect.top, rect.right, rect.bottom)


def capture_image(exclude_taskbar=False):
    screenshot = pyautogui.screenshot()
    if not exclude_taskbar:
        return screenshot

    left, top, right, bottom = get_workarea_bbox()
    return screenshot.crop((left, top, right, bottom))


def append_image_to_document(image_path, width=Inches(5)):
    document.add_picture(image_path, width=width)
    paragraph = document.paragraphs[-1]
    screenshot_doc_entries[os.path.abspath(image_path)] = paragraph._element
    return paragraph


def remove_tracked_image_from_document(image_path):
    element = screenshot_doc_entries.get(os.path.abspath(image_path))
    if element is None:
        return False

    parent = element.getparent()
    if parent is None:
        screenshot_doc_entries.pop(os.path.abspath(image_path), None)
        return False

    parent.remove(element)
    screenshot_doc_entries.pop(os.path.abspath(image_path), None)
    return True


def select_document():
    global document, doc_path, screenshot_doc_entries

    file_path = filedialog.askopenfilename(filetypes=[("Word Files", "*.docx")])
    if not file_path:
        return

    try:
        document = Document(file_path)
        doc_path = file_path
        screenshot_doc_entries = {}
        set_status(f"Selected: {os.path.basename(file_path)}")
    except Exception as exc:
        messagebox.showerror("Open failed", f"Could not open document.\n\n{exc}")


def create_new_document():
    global title_window, title_textbox

    folder = filedialog.askdirectory(title="Select folder to save the new document")
    if not folder:
        set_status("New document cancelled.")
        return

    if title_window is not None and title_window.winfo_exists():
        title_window.destroy()

    title_window = tk.Toplevel(root)
    title_window.title("New Document Title")
    title_window.geometry("480x240+1020+160")
    title_window.configure(bg=CARD_BG)
    title_window.attributes("-topmost", True)

    tk.Label(
        title_window,
        text="Enter document title",
        bg=CARD_BG,
        fg=TEXT_DARK,
        font=("Segoe UI Semibold", 12),
    ).pack(anchor="w", padx=18, pady=(16, 8))

    tk.Label(
        title_window,
        text=f"Folder: {folder}",
        bg=CARD_BG,
        fg="#5d6880",
        font=("Segoe UI", 9),
        wraplength=430,
        justify="left",
    ).pack(anchor="w", padx=18, pady=(0, 8))

    title_textbox = tk.Text(
        title_window,
        height=4,
        width=40,
        wrap="word",
        font=("Segoe UI", 12),
        bd=1,
        relief="solid",
        padx=12,
        pady=12,
        fg=TEXT_DARK,
        highlightthickness=1,
        highlightbackground="#d9deea",
    )
    title_textbox.pack(fill="x", padx=18, pady=(0, 14))
    title_textbox.insert("1.0", datetime.now().strftime("TestDoc_%Y%m%d_%H%M%S"))
    title_textbox.focus_set()

    def save_new_document(_event=None):
        global document, doc_path, title_window, title_textbox, screenshot_doc_entries

        title = title_textbox.get("1.0", tk.END).strip()
        if not title:
            set_status("Enter a title for the new document.")
            return "break"

        filename = os.path.join(folder, f"{title}.docx")
        try:
            document = Document()
            document.add_heading(title, 0)
            document.save(filename)
            doc_path = os.path.abspath(filename)
            screenshot_doc_entries = {}
            set_status(f"Created: {os.path.basename(doc_path)}")
            title_window.destroy()
            title_window = None
            title_textbox = None
        except Exception as exc:
            messagebox.showerror("Create failed", f"Could not create document.\n\n{exc}")
        return "break"

    title_textbox.bind("<Return>", save_new_document)

    action_bar = tk.Frame(title_window, bg=CARD_BG)
    action_bar.pack(fill="x", padx=18, pady=(0, 16))

    tk.Button(
        action_bar,
        text="Create",
        command=save_new_document,
        bg=PRIMARY_BLUE,
        fg="white",
        relief="flat",
        padx=14,
        pady=6,
    ).pack(side="right")

    title_window.protocol("WM_DELETE_WINDOW", lambda: close_title_window())


def close_title_window():
    global title_window, title_textbox

    if title_window is not None and title_window.winfo_exists():
        title_window.destroy()
    title_window = None
    title_textbox = None


def scaled(value):
    return max(1, int(value * ui_scale))


def update_note_style_buttons():
    if note_window is None or not note_window.winfo_exists():
        return

    has_selection = note_textbox is not None and note_textbox.tag_ranges("sel")
    state = "normal" if has_selection else "disabled"
    bold_button.configure(bg="#e8edff", fg=TEXT_DARK, state=state)
    italic_button.configure(bg="#e8edff", fg=TEXT_DARK, state=state)


def save_note_from_window(close_after=False):
    global current_note_text, note_window

    if note_textbox is not None:
        current_note_text = note_textbox.get("1.0", tk.END).strip()

    if current_note_text:
        set_status("Note saved. Press Shot to use it.")
    else:
        set_status("Note cleared.")

    if close_after and note_window is not None and note_window.winfo_exists():
        note_window.withdraw()


def clear_note_editor():
    global current_note_text
    current_note_text = ""

    if note_textbox is not None:
        note_textbox.delete("1.0", tk.END)
        for tag_name in ("bold", "italic", "bold_italic"):
            note_textbox.tag_remove(tag_name, "1.0", tk.END)

    update_note_style_buttons()
    set_status("Note cleared.")


def toggle_bold():
    toggle_selected_text_style("bold")


def toggle_italic():
    toggle_selected_text_style("italic")


def toggle_selected_text_style(style_name):
    if note_textbox is None or not note_textbox.tag_ranges("sel"):
        set_status("Select text in the note box first.")
        update_note_style_buttons()
        return

    start = note_textbox.index("sel.first")
    end = note_textbox.index("sel.last")
    has_bold = style_range_has_tag("bold", start, end) or style_range_has_tag("bold_italic", start, end)
    has_italic = style_range_has_tag("italic", start, end) or style_range_has_tag("bold_italic", start, end)

    if style_name == "bold":
        wants_bold = not has_bold
        wants_italic = has_italic
    else:
        wants_bold = has_bold
        wants_italic = not has_italic

    for tag_name in ("bold", "italic", "bold_italic"):
        note_textbox.tag_remove(tag_name, start, end)

    if wants_bold and wants_italic:
        note_textbox.tag_add("bold_italic", start, end)
    elif wants_bold:
        note_textbox.tag_add("bold", start, end)
    elif wants_italic:
        note_textbox.tag_add("italic", start, end)

    update_note_style_buttons()
    note_textbox.focus_set()


def style_range_has_tag(tag_name, start, end):
    ranges = note_textbox.tag_ranges(tag_name)
    for i in range(0, len(ranges), 2):
        tag_start = ranges[i]
        tag_end = ranges[i + 1]
        if note_textbox.compare(tag_end, ">", start) and note_textbox.compare(tag_start, "<", end):
            return True
    return False


def configure_note_text_tags():
    if note_textbox is None:
        return
    note_textbox.tag_configure("bold", font=("Segoe UI", 10, "bold"))
    note_textbox.tag_configure("italic", font=("Segoe UI", 10, "italic"))
    note_textbox.tag_configure("bold_italic", font=("Segoe UI", 10, "bold italic"))


def add_note_to_document(note):
    if not note or note_textbox is None:
        return

    paragraph = document.add_paragraph()
    index = "1.0"
    end = note_textbox.index("end-1c")
    current_style = None
    buffer = []

    while note_textbox.compare(index, "<", end):
        next_index = note_textbox.index(f"{index} +1c")
        char = note_textbox.get(index, next_index)
        tags = set(note_textbox.tag_names(index))

        if "bold_italic" in tags:
            style = "bold_italic"
        elif "bold" in tags:
            style = "bold"
        elif "italic" in tags:
            style = "italic"
        else:
            style = "normal"

        if current_style is None:
            current_style = style

        if style != current_style:
            append_styled_run(paragraph, "".join(buffer), current_style)
            buffer = []
            current_style = style

        buffer.append(char)
        index = next_index

    if buffer:
        append_styled_run(paragraph, "".join(buffer), current_style)


def append_styled_run(paragraph, text, style):
    run = paragraph.add_run(text)
    if style == "bold":
        run.bold = True
    elif style == "italic":
        run.italic = True
    elif style == "bold_italic":
        run.bold = True
        run.italic = True


def open_note_window():
    global note_window, note_textbox, bold_button, italic_button

    if note_window is not None and note_window.winfo_exists():
        note_window.deiconify()
        note_window.lift()
        note_window.focus_force()
        return

    note_window = tk.Toplevel(root)
    note_window.title("Add Note")
    note_window.geometry("420x320+1020+170")
    note_window.configure(bg=CARD_BG)
    note_window.attributes("-topmost", True)

    header = tk.Label(
        note_window,
        text="Write your note",
        bg=CARD_BG,
        fg=TEXT_DARK,
        font=("Segoe UI Semibold", 12),
    )
    header.pack(anchor="w", padx=16, pady=(14, 6))

    toolbar = tk.Frame(note_window, bg=CARD_BG)
    toolbar.pack(fill="x", padx=16, pady=(0, 8))

    bold_button = tk.Button(toolbar, text="Bold", width=8, command=toggle_bold, relief="flat")
    bold_button.pack(side="left", padx=(0, 8))

    italic_button = tk.Button(toolbar, text="Italic", width=8, command=toggle_italic, relief="flat")
    italic_button.pack(side="left", padx=(0, 8))

    clear_button = tk.Button(
        toolbar,
        text="Clear",
        width=8,
        command=clear_note_editor,
        relief="flat",
        bg="#ffe4e6",
        fg="#8b1e2d",
    )
    clear_button.pack(side="left")

    note_textbox = tk.Text(
        note_window,
        wrap="word",
        font=("Segoe UI", 10),
        bd=1,
        relief="solid",
        padx=10,
        pady=10,
        fg=TEXT_DARK,
        highlightthickness=1,
        highlightbackground="#d9deea",
    )
    note_textbox.pack(fill="both", expand=True, padx=16, pady=(0, 12))
    note_textbox.insert("1.0", current_note_text)
    configure_note_text_tags()
    note_textbox.bind("<<Selection>>", lambda _event: update_note_style_buttons())
    note_textbox.bind("<ButtonRelease-1>", lambda _event: update_note_style_buttons())
    note_textbox.bind("<KeyRelease>", lambda _event: update_note_style_buttons())

    action_bar = tk.Frame(note_window, bg=CARD_BG)
    action_bar.pack(fill="x", padx=16, pady=(0, 14))

    save_button = tk.Button(
        action_bar,
        text="Save & Close",
        command=lambda: save_note_from_window(close_after=True),
        bg=PRIMARY_BLUE,
        fg="white",
        relief="flat",
        padx=12,
        pady=6,
    )
    save_button.pack(side="right")

    note_window.protocol("WM_DELETE_WINDOW", lambda: save_note_from_window(close_after=True))
    update_note_style_buttons()
    note_textbox.focus_set()
    set_status("Type your note, then save and close the note window.")

